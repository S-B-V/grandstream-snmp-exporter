{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source containing the Grandstream exporter metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "Operational overview for Grandstream GCC and AP devices. Uses readable interface names and the AP wireless MIB where available.",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Exporter",
      "description": "1 means the last SNMP collection connected successfully.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "grandstream_exporter_up{device_ip=\"$target\"}", "instant": true, "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "background" }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "value" }
    },
    {
      "id": 2,
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 0 },
      "targets": [{ "expr": "grandstream_host_resources_mib_hrsystemuptime{device_ip=\"$target\"}", "instant": true, "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 3600 }, { "color": "green", "value": 86400 }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "textMode": "auto" }
    },
    {
      "id": 3,
      "title": "Average CPU",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 0 },
      "targets": [{ "expr": "avg(grandstream_host_resources_mib_hrprocessorload{device_ip=\"$target\"})", "instant": true, "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "decimals": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "textMode": "auto" }
    },
    {
      "id": 4,
      "title": "Memory Used",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 0 },
      "targets": [{ "expr": "100 * grandstream_storage_utilization_ratio{device_ip=\"$target\",descr=\"Physical memory\"}", "instant": true, "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "decimals": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] } }, "overrides": [] },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true }
    },
    {
      "id": 5,
      "title": "AP Clients",
      "description": "Shown for DEVICE_TYPE=AP when the Grandstream AP MIB is available.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 0 },
      "targets": [{ "expr": "grandstream_ap_clients{device_ip=\"$target\"}", "instant": true, "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "textMode": "auto" }
    },
    {
      "id": 6,
      "title": "CPU by Core",
      "description": "Core labels are normalized to 0..N instead of the HOST-RESOURCES device indices.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "grandstream_host_resources_mib_hrprocessorload{device_ip=\"$target\"}", "legendFormat": "CPU {{core}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 12, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": true }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 7,
      "title": "Storage and Memory Utilization",
      "description": "Top consumers only; used and total values are no longer mixed as separate bars.",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "topk(10, 100 * grandstream_storage_utilization_ratio{device_ip=\"$target\",descr=~\"Physical memory|/.*\"})", "instant": true, "legendFormat": "{{descr}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "decimals": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "minVizHeight": 16, "minVizWidth": 8, "namePlacement": "left", "orientation": "horizontal", "showUnfilled": true, "sizing": "auto", "valueMode": "color" }
    },
    {
      "id": 8,
      "title": "Network Throughput",
      "description": "64-bit counters; receive is positive and transmit is negative for easy comparison.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "rate(grandstream_if_mib_ifhcinoctets{device_ip=\"$target\",if_name=~\"$interface\"}[$__rate_interval]) * 8", "legendFormat": "{{if_name}} RX", "refId": "A" },
        { "expr": "rate(grandstream_if_mib_ifhcoutoctets{device_ip=\"$target\",if_name=~\"$interface\"}[$__rate_interval]) * -8", "legendFormat": "{{if_name}} TX", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "drawStyle": "line", "fillOpacity": 12, "lineWidth": 2, "showPoints": "never", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 9,
      "title": "Interface Utilization",
      "description": "Traffic divided by reported link speed. Interfaces without a reported speed are omitted.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "100 * rate(grandstream_if_mib_ifhcinoctets{device_ip=\"$target\",if_name=~\"$interface\"}[$__rate_interval]) * 8 / (grandstream_if_mib_ifhighspeed{device_ip=\"$target\",if_name=~\"$interface\"} * 1000000 > 0)", "legendFormat": "{{if_name}} RX", "refId": "A" },
        { "expr": "100 * rate(grandstream_if_mib_ifhcoutoctets{device_ip=\"$target\",if_name=~\"$interface\"}[$__rate_interval]) * 8 / (grandstream_if_mib_ifhighspeed{device_ip=\"$target\",if_name=~\"$interface\"} * 1000000 > 0)", "legendFormat": "{{if_name}} TX", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "spanNulls": true }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 10,
      "title": "Interface Errors and Discards",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "targets": [
        { "expr": "rate(grandstream_if_mib_ifinerrors{device_ip=\"$target\",if_name=~\"$interface\"}[$__rate_interval]) + rate(grandstream_if_mib_ifindiscards{device_ip=\"$target\",if_name=~\"$interface\"}[$__rate_interval])", "legendFormat": "{{if_name}} RX", "refId": "A" },
        { "expr": "rate(grandstream_if_mib_ifouterrors{device_ip=\"$target\",if_name=~\"$interface\"}[$__rate_interval]) + rate(grandstream_if_mib_ifoutdiscards{device_ip=\"$target\",if_name=~\"$interface\"}[$__rate_interval])", "legendFormat": "{{if_name}} TX", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "pps", "min": 0, "custom": { "drawStyle": "bars", "fillOpacity": 30, "lineWidth": 1, "showPoints": "never", "spanNulls": true }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 11,
      "title": "Interface State",
      "description": "UP is green. DOWN is red. Filtered by the interface selector above.",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "targets": [{ "expr": "grandstream_if_mib_ifoperstatus{device_ip=\"$target\",if_name=~\"$interface\"}", "legendFormat": "{{if_name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "2": { "text": "DOWN", "color": "red" }, "3": { "text": "TESTING", "color": "yellow" }, "4": { "text": "UNKNOWN", "color": "gray" }, "5": { "text": "DORMANT", "color": "blue" }, "6": { "text": "NOT PRESENT", "color": "gray" }, "7": { "text": "LOWER LAYER DOWN", "color": "orange" } } }], "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "alignValue": "left", "mergeValues": true, "rowHeight": 0.8, "showValue": "auto", "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 12,
      "title": "AP Radio Configuration",
      "description": "AP only. One bar per radio; channel and transmit-power values come from the Grandstream vendor MIB.",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 28 },
      "targets": [
        { "expr": "grandstream_ap_radio_channel{device_ip=\"$target\"}", "instant": true, "legendFormat": "{{radio_name}} channel", "refId": "A" },
        { "expr": "grandstream_ap_radio_transmit_power{device_ip=\"$target\"}", "instant": true, "legendFormat": "{{radio_name}} power", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "displayMode": "basic", "orientation": "horizontal", "showUnfilled": false, "valueMode": "color" }
    },
    {
      "id": 13,
      "title": "AP Radio Throughput",
      "description": "AP only. Vendor radio counters show aggregate wireless traffic per physical radio.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 28 },
      "targets": [
        { "expr": "rate(grandstream_ap_radio_rx_bytes{device_ip=\"$target\"}[$__rate_interval]) * 8", "legendFormat": "{{radio_name}} RX", "refId": "A" },
        { "expr": "rate(grandstream_ap_radio_tx_bytes{device_ip=\"$target\"}[$__rate_interval]) * -8", "legendFormat": "{{radio_name}} TX", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 14,
      "title": "AP Client Signal",
      "description": "AP only. Current client signal values, labelled with hostname, IP and SSID.",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 28 },
      "targets": [{ "expr": "grandstream_ap_client_signal{device_ip=\"$target\"}", "instant": true, "legendFormat": "{{hostname}} · {{client_ip}} · {{ssid}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 25 }, { "color": "green", "value": 35 }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true, "valueMode": "color" }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": ["grandstream", "snmp", "network"],
  "templating": {
    "list": [
      {
        "name": "target",
        "label": "Device",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(grandstream_exporter_up, device_ip)",
        "query": { "query": "label_values(grandstream_exporter_up, device_ip)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 1,
        "sort": 1,
        "current": {}
      },
      {
        "name": "interface",
        "label": "Interfaces",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(grandstream_if_mib_ifhcinoctets{device_ip=\"$target\"}, if_name)",
        "query": { "query": "label_values(grandstream_if_mib_ifhcinoctets{device_ip=\"$target\"}, if_name)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "regex": "/^(eth[0-9.]+|lan[0-9]+|bond[0-9]+|br-(lan|zone).*|wifi[0-9]+|mld[0-9]+|pppoe.*|wg.*)$/",
        "includeAll": true,
        "allValue": "(eth[0-9]+|lan[0-9]+|pppoe.*|wifi[0-9]+)",
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Grandstream Device Overview",
  "uid": "grandstream-full",
  "version": 1
}
